<Window x:Class="VpnMonitoring.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="400"
        Height="370">

    <Window.Resources>

        <!-- Close / title-bar button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#6B7280"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="5,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark themed slider -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Minimum"   Value="1"/>
            <Setter Property="Maximum"   Value="60"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="Height"    Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#2A2A3E"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="#22C55E"
                                                         Stroke="#1E1E2E" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark checkbox -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="18" Height="18"
                                    CornerRadius="4" Background="#2A2A3E"
                                    BorderBrush="#4B5563" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="Check" Text="✓"
                                           Foreground="#22C55E" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#22C55E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#353550"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button (Save) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#22C55E"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1DAF54"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#189A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (Cancel) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="#4B5563" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════ Root ══════════════════════════════ -->
    <Border CornerRadius="12" Background="#1E1E2E" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="5"
                              Opacity="0.55" Color="#000000" Direction="270"/>
        </Border.Effect>

        <Grid Margin="24,16,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- title bar -->
                <RowDefinition Height="*"/>     <!-- settings -->
                <RowDefinition Height="Auto"/>  <!-- buttons -->
            </Grid.RowDefinitions>

            <!-- ─── Title bar ─── -->
            <Grid Grid.Row="0" Margin="0,0,0,18" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Настройки"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="✕"
                        Style="{StaticResource CloseButtonStyle}"
                        FontSize="13" Foreground="#6B7280"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- ─── Settings controls ─── -->
            <StackPanel Grid.Row="1">

                <!-- Poll interval -->
                <TextBlock Text="Интервал проверки" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="PollSlider"
                            Style="{StaticResource DarkSlider}"
                            Minimum="1" Maximum="60"
                            Value="{Binding PollIntervalSeconds, Mode=TwoWay}"
                            Grid.Column="0"/>
                    <TextBlock Grid.Column="1" Foreground="#E5E7EB" FontSize="13"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               MinWidth="46" TextAlignment="Right"
                               Text="{Binding PollIntervalText}"/>
                </Grid>

                <!-- Notification duration -->
                <TextBlock Text="Длительность уведомлений" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="DurationSlider"
                            Style="{StaticResource DarkSlider}"
                            Minimum="0" Maximum="30"
                            Value="{Binding NotificationDurationSeconds, Mode=TwoWay}"
                            Grid.Column="0"/>
                    <TextBlock Grid.Column="1" Foreground="#E5E7EB" FontSize="13"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               MinWidth="62" TextAlignment="Right"
                               Text="{Binding NotificationDurationText}"/>
                </Grid>

                <!-- Start with Windows -->
                <CheckBox Style="{StaticResource DarkCheckBox}"
                          IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                          Content="Запуск при старте Windows"
                          Margin="0,0,0,14"/>

                <!-- Play sound -->
                <CheckBox Style="{StaticResource DarkCheckBox}"
                          IsChecked="{Binding PlaySound, Mode=TwoWay}"
                          Content="Звуковое уведомление"
                          Margin="0,0,0,0"/>

            </StackPanel>

            <!-- ─── Buttons ─── -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена"
                        Style="{StaticResource SecondaryButton}"
                        Click="CancelButton_Click"
                        Margin="0,0,10,0"/>
                <Button Content="Сохранить"
                        Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
